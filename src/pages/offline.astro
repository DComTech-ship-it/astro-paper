---
import Layout from "@/layouts/Layout.astro";

const offlineMessage = "You're currently offline. Please check your internet connection and try again.";

export default function Offline() {
  return (
    <Layout title="Offline | Bigger Minds">
      <main class="app-layout pb-12">
        <div class="max-w-4xl mx-auto px-4 py-16 text-center">
          <div class="mb-8">
            <h1 class="text-3xl font-bold text-accent mb-4">Offline</h1>
            <p class="text-muted mb-8">{offlineMessage}</p>
          </div>
          
          <div class="text-center">
            <button 
              onclick="window.location.reload()" 
              class="px-6 py-3 bg-accent text-white rounded-lg hover:bg-accent/90 transition-colors"
            >
              Try Again
            </button>
          </div>
        </div>
      </main>
    </Layout>
  );
}
---
